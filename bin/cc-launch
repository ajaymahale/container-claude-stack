#!/usr/bin/env bash
# cc-launch — enter a project container with provider tokens mounted from the
# macOS Keychain.
#
# Flow: read keychain -> write host-side providers.env (0600) -> ensure the
# container image mounts it read-only at /root/.secrets/providers.env -> enter.
# .aliases.sh sources that file; the cc*/claude-mem functions read from env.
# Nothing is baked into the image or committed to git.
set -euo pipefail

PROV_ENV="$HOME/.code-container/providers.env"
SETTINGS="$HOME/.code-container/settings.json"
MOUNT_DEST="/root/.secrets/providers.env"

read_token() { security find-generic-password -a "$USER" -s "$1" -w 2>/dev/null || true; }

ZAI=$(read_token cc-zai-token)
DEEPINFRA=$(read_token cc-deepinfra-token)
DEEPSEEK=$(read_token cc-deepseek-token)
if [ -z "$ZAI" ] && [ -z "$DEEPINFRA" ] && [ -z "$DEEPSEEK" ]; then
  echo "No provider tokens in Keychain. Run: ~/claude-stack/secrets/secrets.bootstrap.sh"
  exit 1
fi

# Refresh providers.env from keychain (host-side, tight perms).
umask 077
: > "$PROV_ENV"
[ -n "$ZAI"       ] && printf 'ZAI_TOKEN=%s\n'       "$ZAI"       >> "$PROV_ENV"
[ -n "$DEEPINFRA" ] && printf 'DEEPINFRA_TOKEN=%s\n' "$DEEPINFRA" >> "$PROV_ENV"
[ -n "$DEEPSEEK"  ] && printf 'DEEPSEEK_TOKEN=%s\n'  "$DEEPSEEK"  >> "$PROV_ENV"
ZAI=""; DEEPINFRA=""; DEEPSEEK=""

# Ensure the shared-SQLite volume exists (all claude containers mount it for one
# cross-container brain; native ext4 in the VM, so SQLite WAL multi-writer is safe).
# Runtime-aware: reads settings.json so docker (OrbStack/home) and podman (work) both work.
RT=$(python3 -c "import json,os;print(json.load(open(os.path.expanduser('~/.code-container/settings.json'))).get('runtime') or 'docker')" 2>/dev/null || echo docker)
"$RT" volume create claude-mem-shared >/dev/null 2>&1 || true

# Wire the container: providers.env mount + shared claude-mem volume + DATA_DIR.
# Strips obsolete mem-server flags (CLAUDE_MEM_SERVER_URL / claude-net / bypass)
# from earlier P3 attempts. Idempotent on init-owned settings.json. If anything
# changed, the per-project container must be removed once to recreate with it.
set +e
python3 - "$SETTINGS" "$PROV_ENV" "$MOUNT_DEST" <<'PY'
import json, os, sys
path, src, dst = sys.argv[1], sys.argv[2], sys.argv[3]
obsolete_vals = {
    "claude-net",
    "CLAUDE_MEM_SERVER_URL=http://mem-server:3100",
    "CLAUDE_MEM_ALLOW_LOCAL_DEV_BYPASS=1",
}
required = [
    ("-v", f"{src}:{dst}:ro"),
    ("-v", "claude-mem-shared:/root/.claude-mem"),
    ("-e", "CLAUDE_MEM_DATA_DIR=/root/.claude-mem"),
]
# Bind-mount ~/.claude.json so the container sees the host's user-scope MCP
# servers (mcpServers lives in ~/.claude.json, NOT under the ~/.claude dir the
# harness already mounts). RW: claude read-modify-writes this file (tips,
# caches, MCP connection state), so RO would break in-container writes.
# ponytail: concurrent host+container writers race on the whole file (last write
# wins) — same accepted risk as the ~/.claude mount (graphify). Upgrade path if
# this bites: switch to in-container install-mcp.sh reading providers.env, drop
# this mount. Only add when the host file exists, else docker makes it a dir.
claude_json = os.path.expanduser("~/.claude.json")
if os.path.exists(claude_json):
    required.append(("-v", f"{claude_json}:/root/.claude.json"))
else:
    print("  ! ~/.claude.json absent — run scripts/install-mcp.sh first;", file=sys.stderr)
    print("    container MCP servers will be unavailable this session.", file=sys.stderr)
with open(path) as f:
    cfg = json.load(f)
drf = cfg.setdefault("dockerRunFlags", [])
cleaned, i = [], 0
while i < len(drf):
    tok, nxt = drf[i], drf[i + 1] if i + 1 < len(drf) else None
    if tok in ("-v", "-e", "--network", "--volume", "--env") and nxt in obsolete_vals:
        i += 2; continue
    cleaned.append(tok); i += 1
changed = cleaned != drf
drf = cleaned
for flag, val in required:
    if val not in drf:
        drf.extend([flag, val]); changed = True
cfg["dockerRunFlags"] = drf
if changed:
    with open(path, "w") as f:
        json.dump(cfg, f, indent=2)
    sys.exit(10)
sys.exit(0)
PY
rc=$?
set -e
if [ "$rc" -eq 10 ]; then
  echo "Container wiring updated in $SETTINGS (providers.env + shared claude-mem volume + DATA_DIR + .claude.json mount)."
  echo "Recreating the container to apply (project is mounted; in-container state is disposable)..."
  container remove 2>/dev/null || true     # no-op if none exists yet (first run)
fi

exec container
