# Template — the live file is generated at runtime by bin/cc-launch from the
# macOS Keychain and mounted read-only into the container at
# /root/.secrets/providers.env (then sourced by .aliases.sh).
#
# Do NOT put real tokens here. This file only documents the variable names.

ZAI_TOKEN=         # z.ai api token — used by ccg
DEEPINFRA_TOKEN=   # deepinfra api token — used by ccdideep
DEEPSEEK_TOKEN=    # deepseek (native) api token — used by ccd
# ccm (anthropic) uses native `claude` login — no token.
